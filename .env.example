DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost

MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=josephine_db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Email Configuration (for password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
# Common SMTP ports: 587 for TLS, 465 for SSL.
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_FROM=noreply@josephineshop.com
EMAIL_TIMEOUT=10

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:3000

# Mercado Pago test or production credentials
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=
SITE_URL=http://127.0.0.1:8000

# WhatsApp contact
CONTACT_WHATSAPP=
CONTACT_WHATSAPP_MESSAGE=Hola, quiero hacer una consulta.

# MinIO / S3 settings (optional)
# Set USE_MINIO=true to enable django-storages S3 backend
USE_MINIO=false
AWS_ACCESS_KEY_ID=minio-access-key
AWS_SECRET_ACCESS_KEY=minio-secret-key
AWS_STORAGE_BUCKET_NAME=products
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ADDRESSING_STYLE=virtual
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_SECURE=false
AWS_DEFAULT_ACL=None
AWS_S3_CUSTOM_DOMAIN=

# Media / static overrides (optional)
MEDIA_URL=/media/
MEDIA_ROOT=./media
